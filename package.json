{
  "name": "eslint-antislop",
  "version": "1.0.0",
  "description": "ESLint 10.x preset for preventing AI-generated code slop",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./recommended": "./configs/recommended.ts",
    "./strict": "./configs/strict.ts",
    "./typescript": "./configs/typescript.ts",
    "./react": "./configs/react.ts"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "ai",
    "slop",
    "code-quality",
    "linting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/knoopx/eslint-antislop"
  },
  "author": "knoopx",
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "scripts": {
    "lint": "bunx eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/visitor-keys": "^8.58.2",
    "@types/esquery": "^1.5.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/rule-tester": "^8.58.2",
    "@typescript-eslint/utils": "^8.58.1",
    "eslint": "^10.0.0",
    "esquery": "^1.7.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "8.58.1",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@typescript-eslint/utils": "$@typescript-eslint/utils"
  }
}
